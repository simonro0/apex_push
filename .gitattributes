# Normalize line endings on commit; checkout uses platform default.
* text=auto

# Force LF for source files to avoid spurious diffs on Windows.
*.dart   text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.gradle text eol=lf
*.kts    text eol=lf
*.xml    text eol=lf
*.swift  text eol=lf
*.cc     text eol=lf
*.cmake  text eol=lf
*.h      text eol=lf

# Binary files — never touch line endings.
*.png    binary
*.jpg    binary
*.mp3    binary
*.wav    binary
*.db     binary
